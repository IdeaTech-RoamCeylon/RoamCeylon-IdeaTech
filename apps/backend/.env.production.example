# Production Environment Template
# ⚠️  Copy to .env on the production server. Never commit this file.
# ⚠️  All values marked CHANGE_ME must be replaced before deployment.

# ─── Database ────────────────────────────────────────────────────────────────
# Use SSL in production — append ?sslmode=require or ?sslmode=verify-full
DATABASE_URL="postgresql://CHANGE_ME:CHANGE_ME@CHANGE_ME:5432/roam_ceylon?sslmode=require"

# ─── Application ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=1d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# ⚠️  No wildcard in production — restrict to your exact frontend domain(s)
CORS_ORIGIN=https://your-app.vercel.app,https://admin.your-app.com

# ─── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_URL=redis://CHANGE_ME:6379

# ─── Logging ──────────────────────────────────────────────────────────────────
# Use 'warn' or 'error' in production to reduce log volume
LOG_LEVEL=warn

# ─── ML / Recommendation Engine ───────────────────────────────────────────────
# Start conservative — can be increased after stability is confirmed
ML_ROLLOUT_PERCENTAGE=50

# ─── Circuit Breaker ──────────────────────────────────────────────────────────
CIRCUIT_BREAKER_THRESHOLD=5
# 5 minutes in production
CIRCUIT_BREAKER_RESET_MS=300000

# ─── Recommendation Cache ─────────────────────────────────────────────────────
# Longer TTLs in production reduce DB load
RECOMMENDATION_CACHE_TTL_MS=600000
PROFILE_CACHE_TTL_MS=1800000

# ─── Google / OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
