# Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# ⚠️  Never commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Nhost / self-hosted / Railway / Supabase)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/roam_ceylon"

# ─── Application ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Authentication ───────────────────────────────────────────────────────────
# Long random string — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (use * only in development)
CORS_ORIGIN=*

# ─── Redis (optional — used by cache-manager in future) ───────────────────────
REDIS_URL=redis://localhost:6379

# ─── Logging ──────────────────────────────────────────────────────────────────
# One of: error | warn | info | debug | verbose
LOG_LEVEL=debug

# ─── ML / Recommendation Engine ───────────────────────────────────────────────
# Percentage of users who receive ML-powered recommendations (0–100)
ML_ROLLOUT_PERCENTAGE=50

# ─── Circuit Breaker (Day 66 / Fail-Safe) ─────────────────────────────────────
# Number of consecutive failures before the circuit opens
CIRCUIT_BREAKER_THRESHOLD=5
# How long (ms) the circuit stays OPEN before testing recovery (HALF_OPEN)
CIRCUIT_BREAKER_RESET_MS=300000

# ─── Recommendation Cache ─────────────────────────────────────────────────────
# TTL for full recommendation results (ms) — default 5 minutes
RECOMMENDATION_CACHE_TTL_MS=300000
# TTL for user feature profile cache (ms) — default 10 minutes
PROFILE_CACHE_TTL_MS=600000

# ─── Google / OAuth (if used) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
