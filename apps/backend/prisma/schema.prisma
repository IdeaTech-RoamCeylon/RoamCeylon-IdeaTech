generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [citext(schema: "public"), postgis, vector]
}

model DriverLocation {
  id        Int                     @id @default(autoincrement())
  driverId  String
  location  Unsupported("geometry")
  updatedAt DateTime

  @@index([location], map: "driver_location_idx", type: Gist)
  @@index([driverId], map: "driver_id_idx")
}

model RideRequest {
  id             Int                     @id @default(autoincrement())
  passengerId    String
  pickupLocation Unsupported("geometry")
  destination    Unsupported("geometry")
  status         String
  createdAt      DateTime                @default(now())

  @@index([pickupLocation], map: "ride_request_pickup_idx", type: Gist)
  @@index([destination], map: "ride_request_dest_idx", type: Gist)
  @@index([passengerId], map: "ride_request_passenger_idx")
  @@index([status], map: "ride_request_status_idx")
}

model SystemMetadata {
  key       String   @id
  value     String
  updatedAt DateTime
}

model User {
  id             String    @id @default(uuid())
  phoneNumber    String?   @unique @map("phone")
  name           String?
  createdAt      DateTime  @default(now())
  email          String?
  updatedAt      DateTime  @default(now()) @updatedAt
  birthday       DateTime?
  gender         String?
  preferences    Json?
  authProvider   String?   @default("phone") @map("auth_provider")
  googleId       String?   @unique @map("google_id")
  profilePicture String?   @map("profile_picture")
  isLocal        Boolean?  @default(true) @map("is_local")
}

model AdminUser {
  id              String   @id @default(uuid())
  name            String?
  email           String?  @unique
  phoneNumber     String?  @unique @map("phone")
  role            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  profile_picture String?
  preferences     Json?

  @@map("admin_users")
}

model embeddings {
  id         Int                    @id @default(autoincrement())
  embedding  Unsupported("vector")?
  created_at DateTime               @default(now())
  content    String?
  title      String?

  @@index([title])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

model SavedTrip {
  userId        String
  name          String
  destination   String
  startDate     DateTime
  endDate       DateTime
  itinerary     Json
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  preferences   Json?
  id            String       @id
  chatSessionId String?      @map("chat_session_id")
  chatSession   ChatSession? @relation(fields: [chatSessionId], references: [id])

  @@index([userId, createdAt])
  @@index([destination])
  @@index([chatSessionId])
  @@map("SavedTrip")
}

model PlannerFeedback {
  userId        String
  tripId        String
  createdAt     DateTime @default(now())
  feedbackValue Json
  id            Int      @id @default(autoincrement())
  updatedAt     DateTime @default(now()) @updatedAt

  @@unique([userId, tripId], name: "unique_user_trip_feedback")
  @@index([tripId])
  @@index([userId])
  @@index([createdAt])
  @@map("PlannerFeedback")
}

model UserCategoryWeight {
  id            Int      @id @default(autoincrement())
  userId        String
  category      String
  weight        Float    @default(1.0)
  feedbackCount Int      @default(0)
  lastUpdated   DateTime @default(now())

  @@unique([userId, category])
  @@index([userId])
  @@map("UserCategoryWeight")
}

model UserFeedbackSignal {
  id            Int      @id @default(autoincrement())
  userId        String   @unique
  positiveCount Int      @default(0)
  negativeCount Int      @default(0)
  neutralCount  Int      @default(0)
  trustScore    Float    @default(0.5)
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model TransportSession {
  id             String    @id @default(uuid())
  passengerId    String
  driverId       String?
  status         String
  pickupLocation Json
  destination    Json
  fare           Decimal?
  startTime      DateTime  @default(now())
  endTime        DateTime?
  statusUpdates  Json[]    @default([])

  @@index([passengerId])
  @@index([driverId])
  @@index([status])
}

model PlannerMetadata {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model PlannerEvent {
  id        String   @id @default(uuid())
  userId    String?
  eventType String
  metadata  Json     @default("{}")
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([timestamp])
  @@index([eventType, timestamp])
}

model FeedbackEvent {
  id        String   @id
  userId    String?
  eventType String
  metadata  Json     @default("{}")
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([timestamp])
  @@index([eventType, timestamp])
}

model SystemMetric {
  id        String   @id @default(uuid())
  userId    String?
  eventType String
  metadata  Json     @default("{}")
  timestamp DateTime @default(now())

  @@index([eventType])
  @@index([timestamp])
  @@index([eventType, timestamp])
}

model SystemAlert {
  id          String    @id @default(uuid())
  type        String
  severity    String
  metricValue Float
  threshold   Float
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  @@index([type])
  @@index([severity])
  @@index([createdAt])
  @@index([resolvedAt])
}

model UserBehaviorEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")
  eventType String   @map("event_type")
  itemId    String?  @map("item_id")
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("user_behavior_events")
}

model RecommendationLog {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id")
  recommendationId String?  @map("recommendation_id")
  itemId           String?  @map("item_id")
  score            Float?
  mlScore          Float?   @map("ml_score")
  ruleScore        Float?   @map("rule_score")
  finalScore       Float?   @map("final_score")
  source           String?  @default("rule-based") @map("source")
  clicked          Boolean? @default(false)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("recommendation_logs")
}

model UserInterestProfile {
  userId            String   @id @map("user_id")
  culturalScore     Int      @default(0) @map("cultural_score")
  adventureScore    Int      @default(0) @map("adventure_score")
  relaxationScore   Int      @default(0) @map("relaxation_score")
  timeOfDayPrefs    Json?    @map("time_of_day_prefs")
  categoryDiversity Float?   @default(0) @map("category_diversity")
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("user_interest_profile")
}

model DestinationCategoryScore {
  destinationId   String   @id @map("destination_id")
  category        String
  popularityScore Float    @map("popularity_score")
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("destination_category_scores")
}

model FeedbackSummary {
  userId           String   @id @map("user_id")
  positiveFeedback Int      @default(0) @map("positive_feedback")
  negativeFeedback Int      @default(0) @map("negative_feedback")
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("feedback_summary")
}

model PendingFeedbackLearning {
  id           Int      @id @default(autoincrement())
  userId       String
  tripId       String
  rating       Int
  category     String
  queuedAt     DateTime @default(now())
  processAfter DateTime

  @@unique([userId, tripId])
  @@index([processAfter])
  @@index([userId])
}

model ChatSession {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  messages  Message[]
  tripPlans SavedTrip[]

  @@index([userId])
  @@map("ChatSession")
}

model Message {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  sender    String
  content   Json
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("Message")
}

model PlaceCache {
  id        String   @id @default(uuid())
  placeName String   @unique
  imageUrl  String
  updatedAt DateTime @default(now())

  @@map("PlaceCache")
}

model Shop {
  id            String   @id @default(uuid())
  ownerId       String   @map("owner_id")
  name          String
  category      String
  description   String   @default("")
  coverImageUrl String   @default("") @map("cover_image_url")
  status        String   @default("under_review")
  hoursEnabled  Boolean  @default(false) @map("hours_enabled")
  hoursText     String   @default("") @map("hours_text")
  website       String   @default("")
  instagram     String   @default("")
  facebook      String   @default("")
  tiktok        String   @default("")
  location      String   @default("")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([ownerId])
  @@index([status])
  @@map("shops")
}

model TourPackage {
  id                 String          @id @default(uuid())
  guideId            String          @map("guide_id")
  name               String
  category           String
  description        String          @default("")
  coverImageUrl      String          @default("") @map("cover_image_url")
  duration           Int             @default(1)
  price              Decimal         @default(0) @db.Decimal(10, 2)
  highlights         Json            @default("[]")
  location           String          @default("")
  status             String          @default("draft")
  publishImmediately Boolean         @default(true) @map("publish_immediately")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  galleryUrls        Json            @default("[]") @map("gallery_urls")
  tour_bookings      tour_bookings[]

  @@index([guideId])
  @@index([status])
  @@map("tour_packages")
}

model Activity {
  id              String            @id @default(uuid())
  providerId      String            @map("provider_id")
  name            String
  category        String
  description     String            @default("")
  coverImageUrl   String            @default("") @map("cover_image_url")
  difficulty      String            @default("easy")
  startTime       String            @default("") @map("start_time")
  endTime         String            @default("") @map("end_time")
  location        String            @default("")
  price           Decimal           @default(0) @db.Decimal(10, 2)
  maxParticipants Int               @default(20) @map("max_participants")
  status          String            @default("active")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  date            DateTime?
  bookings        ActivityBooking[]

  @@index([providerId])
  @@index([status])
  @@map("activities")
}

model ActivityBooking {
  id            String   @id @default(uuid())
  activityId    String   @map("activity_id")
  providerId    String   @map("provider_id")
  customerName  String   @map("customer_name")
  customerEmail String   @default("") @map("customer_email")
  guests        Int      @default(1)
  amount        Decimal  @default(0) @db.Decimal(10, 2)
  scheduledDate DateTime @map("scheduled_date")
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  activity      Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([activityId])
  @@index([status])
  @@map("activity_bookings")
}

model tour_bookings {
  id               String      @id
  package_id       String
  guide_id         String
  customer_id      String?
  customer_name    String
  customer_email   String      @default("")
  customer_avatar  String      @default("")
  tour_name        String
  start_date       DateTime
  end_date         DateTime
  guests           Int         @default(1)
  amount           Decimal     @default(0) @db.Decimal(10, 2)
  status           String      @default("pending")
  created_at       DateTime    @default(now())
  updated_at       DateTime
  customer_phone   String      @default("")
  pickup_location  String      @default("")
  special_requests String      @default("")
  tour_packages    TourPackage @relation(fields: [package_id], references: [id], onDelete: Cascade)

  @@index([guide_id])
  @@index([package_id])
  @@index([status])
}

model tour_inquiries {
  id             String   @id
  guide_id       String
  guest_name     String
  guest_email    String   @default("")
  guest_avatar   String   @default("")
  subject        String   @default("")
  message        String   @default("")
  status         String   @default("new")
  tour_interest  String   @default("")
  pipeline_value Decimal  @default(0) @db.Decimal(10, 2)
  created_at     DateTime @default(now())
  updated_at     DateTime

  @@index([guide_id])
  @@index([status])
}

model tour_notifications {
  id                String   @id
  guide_id          String
  type              String   @default("system")
  title             String
  message           String   @default("")
  is_read           Boolean  @default(false)
  related_entity_id String?
  created_at        DateTime @default(now())

  @@index([guide_id])
  @@index([is_read])
}

// ─── Hotel Booking Models (managed by RoamCeylonAdmin/backend; read-only here) ─

model Hotel {
  id            String   @id @default(uuid())
  ownerId       String   @unique @map("owner_id")
  name          String
  category      String   @default("")
  description   String   @default("")
  streetAddress String   @default("") @map("street_address")
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  amenities     Json     @default("[]")
  coverImageUrl String   @default("") @map("cover_image_url")
  galleryUrls   Json     @default("[]") @map("gallery_urls")
  status        String   @default("active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  rooms Room[]

  @@index([ownerId])
  @@map("hotels")
}

model Room {
  id             String   @id @default(uuid())
  ownerId        String   @map("owner_id")
  hotelId        String?  @map("hotel_id")
  name           String
  roomType       String   @default("") @map("room_type")
  squareFootage  Int      @default(0) @map("square_footage")
  adults         Int      @default(2)
  availableUnits Int      @default(1) @map("available_units")
  nightlyRate    Decimal  @default(0) @map("nightly_rate") @db.Decimal(10, 2)
  amenities      Json     @default("[]")
  coverImageUrl  String   @default("") @map("cover_image_url")
  galleryUrls    Json     @default("[]") @map("gallery_urls")
  status         String   @default("available")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  hotel Hotel? @relation(fields: [hotelId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([hotelId])
  @@index([status])
  @@map("rooms")
}
