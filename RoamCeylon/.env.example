# Environment Variables

# API Configuration
# For local development against NestJS backend, set this to http://localhost:3001 or your local IP (e.g. http://192.168.x.x:3001)
EXPO_PUBLIC_API_URL=https://api.roamceylon.com

# Mapbox Configuration
# Get your tokens from: https://account.mapbox.com/access-tokens
# 1. Public Access Token (starts with 'pk.') - Used at runtime for map rendering
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_public_access_token_here

# Note: Download Token (starts with 'sk.') goes in app.json under plugins > @rnmapbox/maps > RNMapboxMapsDownloadToken
# This token is used during the build process to download Mapbox maps

# Nhost Configuration
# Get these from your Nhost project dashboard
EXPO_PUBLIC_NHOST_SUBDOMAIN=your_nhost_subdomain_here
EXPO_PUBLIC_NHOST_REGION=your_nhost_region_here

# Google OAuth Configuration
# Needed for Google Sign-in on GoogleSignInScreen
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here
